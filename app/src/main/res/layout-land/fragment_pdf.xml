<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="76dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="8dp"
        android:gravity="top|center_horizontal"
        android:background="#F7F7F7">

        <Button
            android:id="@+id/btnSave"
            android:layout_width="58dp"
            android:layout_height="42dp"
            android:text="S" />

        <Button
            android:id="@+id/btnText"
            android:layout_width="58dp"
            android:layout_height="42dp"
            android:layout_marginTop="8dp"
            android:text="T" />

        <Button
            android:id="@+id/btnPen"
            android:layout_width="58dp"
            android:layout_height="42dp"
            android:layout_marginTop="8dp"
            android:text="P" />

        <Button
            android:id="@+id/btnEraser"
            android:layout_width="58dp"
            android:layout_height="42dp"
            android:layout_marginTop="8dp"
            android:text="E" />

        <Button
            android:id="@+id/btnToggleWhiteboard"
            android:layout_width="58dp"
            android:layout_height="42dp"
            android:layout_marginTop="8dp"
            android:text="H" />

        <Button
            android:id="@+id/btnAddWhitePage"
            android:layout_width="58dp"
            android:layout_height="42dp"
            android:layout_marginTop="8dp"
            android:text="+" />

        <SeekBar
            android:id="@+id/sizeSeekBar"
            android:layout_width="160dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:rotation="270"
            android:translationX="-42dp"
            android:translationY="62dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="6dp">

                <ImageButton
                    android:id="@+id/btnPrevious"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@android:drawable/ic_media_previous"
                    android:background="@android:color/transparent"
                    android:contentDescription="Previous PDF page" />

                <TextView
                    android:id="@+id/tvPageNumber"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Page 1 / 1"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#111111" />

                <ImageButton
                    android:id="@+id/btnNext"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@android:drawable/ic_media_next"
                    android:background="@android:color/transparent"
                    android:contentDescription="Next PDF page" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/pdfContainer"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_margin="8dp"
                android:background="#FFFFFF">

                <ImageView
                    android:id="@+id/pdfImageView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter"
                    android:adjustViewBounds="true" />

                <FrameLayout
                    android:id="@+id/pdfTapLayer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:clickable="true" />

                <FrameLayout
                    android:id="@+id/pdfTextOverlay"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent" />
            </FrameLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/whitePane"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="6dp">

                <ImageButton
                    android:id="@+id/btnPrevWhite"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@android:drawable/arrow_up_float"
                    android:background="@android:color/transparent"
                    android:contentDescription="Previous white page" />

                <TextView
                    android:id="@+id/tvWhitePageNumber"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="W 1 / 1"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#111111" />

                <ImageButton
                    android:id="@+id/btnNextWhite"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@android:drawable/arrow_down_float"
                    android:background="@android:color/transparent"
                    android:contentDescription="Next white page" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/whiteboardContainer"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_margin="8dp"
                android:background="#FFFFFF">

                <com.example.myapplication.ui.pdf.DrawingView
                    android:id="@+id/drawingView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <FrameLayout
                    android:id="@+id/whiteTapLayer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:clickable="true" />

                <FrameLayout
                    android:id="@+id/whiteTextOverlay"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent" />
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
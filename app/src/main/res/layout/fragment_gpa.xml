<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F6F0F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvGpaTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Average Calculator"
            android:textColor="#2B2233"
            android:textSize="28sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etCourseName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:hint="Course name"
            android:inputType="textCapWords" />

        <EditText
            android:id="@+id/etCredits"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Coefficient"
            android:inputType="numberDecimal" />

        <EditText
            android:id="@+id/etGradePoint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Grade on 20"
            android:inputType="numberDecimal" />

        <Button
            android:id="@+id/btnAddCourse"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:text="Add Course"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnCalculateGpa"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="Calculate Average"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnClearCourses"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="Clear Courses"
            android:textAllCaps="false" />

        <TextView
            android:id="@+id/tvGpaResult"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Average: 0.00 / 20"
            android:textColor="#2B2233"
            android:textSize="24sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/coursesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical" />

    </LinearLayout>
</ScrollView>